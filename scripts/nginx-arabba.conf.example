# Example nginx config for arabba.hr production.
# GitHub push webhook → scripts/github-deploy-webhook.js (systemd, port 19082)

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name arabba.hr www.arabba.hr;

    root /var/www/arabba;
    index index.html;

    location /hooks/deploy {
        proxy_pass http://127.0.0.1:19082/hooks/deploy;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Hub-Signature-256 $http_x_hub_signature_256;
        proxy_set_header X-GitHub-Event $http_x_github_event;
        proxy_set_header X-GitHub-Delivery $http_x_github_delivery;
        proxy_read_timeout 30s;
        client_max_body_size 1m;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
